{
  "mcpServers": {
    "filesystem": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/allowed/files"
      ],
      "env": {},
      "description": "Provides filesystem access within allowed directories"
    },
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    }
  },
  "skills": {
    "ethoinsight": {
      "enabled": true
    },
    "ethoinsight-metric-catalog": {
      "enabled": true
    },
    "ethovision-paradigm-knowledge": {
      "enabled": true
    },
    "ethoinsight-grouping": {
      "enabled": true
    },
    "ethoinsight-column-confirmation": {
      "enabled": true
    },
    "ethoinsight-lead-interaction": {
      "enabled": true
    },
    "ethoinsight-code": {
      "enabled": true
    },
    "ethoinsight-charts": {
      "enabled": true
    },
    "ethoinsight-chart-maker": {
      "enabled": true
    }
  }
}
